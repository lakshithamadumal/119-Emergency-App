<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF6F8">

    <View
        android:id="@+id/topCard"
        android:layout_width="0dp"
        android:layout_height="266dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/top_card_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/statsBar"
        android:layout_width="336dp"
        android:layout_height="63dp"
        android:background="@drawable/stats_bar_bg"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/topCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="25dp"
            android:text="ACTIVE REPORTS"
            android:textColor="#201C21"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="110dp"
            android:layout_height="45dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_bg"
            android:backgroundTint="#03CFB7"
            android:gravity="center"
            android:text="15,346+"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sosButton"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/sos_button_bg"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavSection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statsBar">

        <ImageView
            android:id="@+id/sosIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/ic_sos_wifi"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOS"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/sosIcon"
            android:layout_marginBottom="55dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavSection"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:id="@+id/navBar"
            android:layout_width="282dp"
            android:layout_height="68dp"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bottom_nav_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/home_icon_bg"
            app:layout_constraintBottom_toBottomOf="@+id/navBar"
            app:layout_constraintStart_toStartOf="@+id/navBar"
            app:layout_constraintTop_toTopOf="@+id/navBar">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_gravity="center"
                android:src="@drawable/home" />
        </FrameLayout>

        <ImageView android:id="@+id/ivDoc" android:layout_width="25dp" android:layout_height="25dp" android:layout_marginStart="100dp" android:src="@drawable/report" app:layout_constraintBottom_toBottomOf="@+id/navBar" app:layout_constraintStart_toStartOf="@+id/navBar" app:layout_constraintTop_toTopOf="@+id/navBar" />
        <ImageView android:id="@+id/ivProfile" android:layout_width="25dp" android:layout_height="25dp" android:layout_marginStart="160dp" android:src="@drawable/profile" app:layout_constraintBottom_toBottomOf="@+id/navBar" app:layout_constraintStart_toStartOf="@+id/navBar" app:layout_constraintTop_toTopOf="@+id/navBar" />
        <ImageView android:id="@+id/ivSettings" android:layout_width="25dp" android:layout_height="25dp" android:layout_marginStart="220dp" android:src="@drawable/settings" app:layout_constraintBottom_toBottomOf="@+id/navBar" app:layout_constraintStart_toStartOf="@+id/navBar" app:layout_constraintTop_toTopOf="@+id/navBar" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/navBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/navBar">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/call_icon_border" />

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/sos_button_bg"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center"
                    android:src="@drawable/call" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>