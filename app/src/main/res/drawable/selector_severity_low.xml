<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#E8F5E9" /> <stroke
            android:width="2dp"
            android:color="#4CAF50" /> <corners android:radius="25dp" />
        </shape>
    </item>

    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="#F1F1F1" /> <stroke
            android:width="1dp"
            android:color="#CCCCCC" /> <corners android:radius="25dp" />
        </shape>
    </item>
</selector>