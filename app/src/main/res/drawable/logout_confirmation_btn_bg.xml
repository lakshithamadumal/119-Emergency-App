<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/mainRed" /> <stroke
            android:width="2dp"
            android:color="@color/mainRed" /> <corners android:radius="13dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/mainRed" />
            <stroke
                android:width="1dp"
                android:color="@color/mainRed" /> <corners android:radius="13dp" />
        </shape>
    </item>

</selector>